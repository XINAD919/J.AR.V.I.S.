    {
      "parameters": {
        "jsCode": "// Error Trigger  has no reminder_id from original payload.\n// Extract what we can; stop execution if reminder_id is unavailable.\nconst execution =  $input.first().json.execution || {};\nconst reminderId = $json.reminder_id || null;\n\nif (!reminderId) {\n  // No way to identify which reminder failed — skip DB update\n  return [];\n}\n\nreturn [{\n  json: {\n    reminder_id: reminderId,\n    error_message: execution.error?.message || $json.error?.message || 'Unknown error'\n  }\n}];"
      },
