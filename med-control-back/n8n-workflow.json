    },
    {
      "parameters": {
        "jsCode": "const data = $('Wait Until Scheduled Time').first().json;\nconst scheduledAt = new Date(new Date(data.created_at).getTime() + data.delay_minutes * 60000);\nconst endDate = new Date(data.recurrence_end_date);\nconst now = new Date();\nlet nextDate = new Date(scheduledAt);\n\nswitch (data.recurrence_type) {\n  case 'daily':\n    nextDate.setDate(nextDate.getDate() + 1);\n    break;\n  case 'weekly': {\n    const days = JSON.parse(data.recurrence_days || '[]');\n    nextDate.setDate(nextDate.getDate() + 1);\n    let safety = 0;\n    while (!days.includes(nextDate.getDay()) && safety++ < 8) nextDate.setDate(nextDate.getDate() + 1);\n    break;\n  }\n  case 'weekdays':\n    nextDate.setDate(nextDate.getDate() + 1);\n    while ([0,6].includes(nextDate.getDay())) nextDate.setDate(nextDate.getDate() + 1);\n    break;\n  case 'weekends':\n    nextDate.setDate(nextDate.getDate() + 1);\n    while (![0,6].includes(nextDate.getDay())) nextDate.setDate(nextDate.getDate() + 1);\n    break;\n  case 'monthly':\n    nextDate.setMonth(nextDate.getMonth() + 1);\n    break;\n  case 'interval_days':\n    nextDate.setDate(nextDate.getDate() + (data.recurrence_interval || 1));\n    break;\n  case 'interval_hours':\n    nextDate = new Date(scheduledAt.getTime() + (data.recurrence_interval || 1) * 3600000);\n    break;\n  default:\n    return [{ json: { should_requeue: false } }];\n}\n\nif (nextDate > endDate) return [{ json: { should_requeue: false } }];\n\nconst delayMinutes = Math.max(1, Math.floor((nextDate.getTime() - now.getTime()) / 60000));\nconst newReminderId = 'rem_' + Math.floor(nextDate.getTime() / 1000);\n\nreturn [{ json: { ...data, reminder_id: newReminderId, delay_minutes: delayMinutes, created_at: now.toISOString(), should_requeue: true } }];"
      },
