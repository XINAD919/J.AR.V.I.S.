    {
      "parameters": {
        "operation": "executeQuery",
        "query": "WITH ins AS (\n  INSERT INTO reminders (\n    reminder_id, user_id, session_id,\n    medication, schedule, message, notes,\n    channel, notify_id, scheduled_at, status, created_at,\n    is_recurring, recurrence_type, recurrence_days, recurrence_interval, recurrence_end_date\n  )\n  VALUES (\n    '{{ $json.reminder_id }}',\n    '{{ $json.user_id }}'::uuid,\n    (SELECT id FROM sessions WHERE session_id = '{{ $json.session_id }}' LIMIT 1),\n    '{{ $json.medication }}',\n    '{{ $json.schedule }}',\n    '{{ $json.message }}',\n    NULLIF('{{ $json.notes }}', ''),\n    '{{ $json.channel }}'::channel_type,\n    '{{ $json.notify_id }}',\n    (TIMESTAMPTZ '{{ $json.created_at }}' + INTERVAL '1 minute' * {{ $json.delay_minutes }}),\n    'scheduled',\n    NOW(),\n    {{ $json.is_recurring }},\n    NULLIF('{{ $json.recurrence_type }}', ''),\n    NULLIF('{{ $json.recurrence_days }}', ''),\n    {{ $json.recurrence_interval }},\n    NULLIF('{{ $json.recurrence_end_date }}', '')::TIMESTAMP\n  )\n  ON CONFLICT (reminder_id, channel) DO NOTHING\n)\nSELECT\n  '{{ $json.reminder_id }}'          AS reminder_id,\n  '{{ $json.user_id }}'              AS user_id,\n  '{{ $json.session_id }}'           AS session_id,\n  '{{ $json.medication }}'           AS medication,\n  '{{ $json.schedule }}'             AS schedule,\n  '{{ $json.message }}'              AS message,\n  '{{ $json.notes }}'                AS notes,\n  '{{ $json.channel }}'              AS channel,\n  '{{ $json.notify_id }}'            AS notify_id,\n  {{ $json.delay_minutes }}::int     AS delay_minutes,\n  '{{ $json.created_at }}'           AS created_at,\n  '{{ $json.onesignal_app_id }}'     AS onesignal_app_id,\n  '{{ $json.discord_webhook_url }}'  AS discord_webhook_url,\n  {{ $json.is_recurring }}           AS is_recurring,\n  '{{ $json.recurrence_type }}'      AS recurrence_type,\n  '{{ $json.recurrence_days }}'      AS recurrence_days,\n  {{ $json.recurrence_interval }}    AS recurrence_interval,\n  '{{ $json.recurrence_end_date }}'  AS recurrence_end_date,\n  '{{ $json.n8n_webhook_url }}'      AS n8n_webhook_url",
        "options": {}
      },
      "id": "5573a638-4fc1-4be1-bcff-61b67916958d",
