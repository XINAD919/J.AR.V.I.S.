    {
      "parameters": {
        "jsCode": "// ── Generate .ics calendar file ──────────────────────────────\nconst data = $input.first().json;\nconst dataFromParseData = $(\"Parse Data\").first().json;\n// Calculate event start\nconst startDate = new Date(\n  new Date(data.created_at).getTime() + dataFromParseData.delay_minutes * 60 * 1000,\n);\nconst endDate = new Date(startDate.getTime() + 15 * 60 * 1000);\n\nconst formatDate = (d) =>\n  d.toISOString().replace(/[-:]/g, \"\").split(\".\")[0] + \"Z\";\n\nconst uid = `medai-${data.reminder_id}@medai.local`;\n\nconst icsLines = [\n  \"BEGIN:VCALENDAR\",\n  \"VERSION:2.0\",\n  \"PRODID:-//MedAI//Medication Reminder//ES\",\n  \"CALSCALE:GREGORIAN\",\n  \"METHOD:PUBLISH\",\n  \"BEGIN:VEVENT\",\n  `UID:${uid}`,\n  `DTSTAMP:${formatDate(new Date())}`,\n  `DTSTART:${formatDate(startDate)}`,\n  `DTEND:${formatDate(endDate)}`,\n  `SUMMARY:💊 ${data.medication}`,\n  `DESCRIPTION:${data.message}\\\\n\\\\nNotas: ${data.notes}`,\n  \"BEGIN:VALARM\",\n  \"TRIGGER:-PT0M\",\n  \"ACTION:DISPLAY\",\n  `DESCRIPTION:${data.message}`,\n  \"END:VALARM\",\n  \"END:VEVENT\",\n  \"END:VCALENDAR\",\n];\n\nconst icsContent = icsLines.join(\"\\r\\n\");\nconst buffer = Buffer.from(icsContent, \"utf8\");\nconst binaryData = await this.helpers.prepareBinaryData(\n  buffer,\n  `${data.medication.replace(/\\s+/g, \"_\")}.ics`,\n  \"text/calendar\",\n);\n\nreturn { json: data, binary: { ics: binaryData } };\n"
      },
